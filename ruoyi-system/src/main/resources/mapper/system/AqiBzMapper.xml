<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AqiBzMapper">
    
    <resultMap type="AqiBz" id="AqiBzResult">
        <result property="levelId"    column="level_id"    />
        <result property="aqiLevel"    column="aqi_level"    />
        <result property="description"    column="description"    />
        <result property="colorName"    column="color_name"    />
        <result property="colorCode"    column="color_code"    />
        <result property="createdAt"    column="created_at"    />
        <result property="updatedAt"    column="updated_at"    />
    </resultMap>

    <sql id="selectAqiBzVo">
        select level_id, aqi_level, description, color_name, color_code, created_at, updated_at from aqi_bz
    </sql>

    <select id="selectAqiBzList" parameterType="AqiBz" resultMap="AqiBzResult">
        <include refid="selectAqiBzVo"/>
        <where>  
            <if test="aqiLevel != null  and aqiLevel != ''"> and aqi_level = #{aqiLevel}</if>
            <if test="description != null  and description != ''"> and description = #{description}</if>
            <if test="colorName != null  and colorName != ''"> and color_name like concat('%', #{colorName}, '%')</if>
            <if test="colorCode != null  and colorCode != ''"> and color_code = #{colorCode}</if>
            <if test="createdAt != null "> and created_at = #{createdAt}</if>
            <if test="updatedAt != null "> and updated_at = #{updatedAt}</if>
        </where>
    </select>
    
    <select id="selectAqiBzByLevelId" parameterType="Integer" resultMap="AqiBzResult">
        <include refid="selectAqiBzVo"/>
        where level_id = #{levelId}
    </select>

    <insert id="insertAqiBz" parameterType="AqiBz">
        insert into aqi_bz
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="levelId != null">level_id,</if>
            <if test="aqiLevel != null and aqiLevel != ''">aqi_level,</if>
            <if test="description != null and description != ''">description,</if>
            <if test="colorName != null and colorName != ''">color_name,</if>
            <if test="colorCode != null and colorCode != ''">color_code,</if>
            <if test="createdAt != null">created_at,</if>
            <if test="updatedAt != null">updated_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="levelId != null">#{levelId},</if>
            <if test="aqiLevel != null and aqiLevel != ''">#{aqiLevel},</if>
            <if test="description != null and description != ''">#{description},</if>
            <if test="colorName != null and colorName != ''">#{colorName},</if>
            <if test="colorCode != null and colorCode != ''">#{colorCode},</if>
            <if test="createdAt != null">#{createdAt},</if>
            <if test="updatedAt != null">#{updatedAt},</if>
         </trim>
    </insert>

    <update id="updateAqiBz" parameterType="AqiBz">
        update aqi_bz
        <trim prefix="SET" suffixOverrides=",">
            <if test="aqiLevel != null and aqiLevel != ''">aqi_level = #{aqiLevel},</if>
            <if test="description != null and description != ''">description = #{description},</if>
            <if test="colorName != null and colorName != ''">color_name = #{colorName},</if>
            <if test="colorCode != null and colorCode != ''">color_code = #{colorCode},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
        </trim>
        where level_id = #{levelId}
    </update>

    <delete id="deleteAqiBzByLevelId" parameterType="Integer">
        delete from aqi_bz where level_id = #{levelId}
    </delete>

    <delete id="deleteAqiBzByLevelIds" parameterType="String">
        delete from aqi_bz where level_id in 
        <foreach item="levelId" collection="array" open="(" separator="," close=")">
            #{levelId}
        </foreach>
    </delete>
</mapper>